{
  "version": 2,
  "builds": [
    {
      "src": "wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "wsgi.py"
    }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini-api-key",
    "FLASK_ENV": "production"
  },
  "functions": {
    "wsgi.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}

{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini-api-key",
    "FLASK_ENV": "production",
    "FLASK_SECRET_KEY": "@flask-secret-key"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  }
}
